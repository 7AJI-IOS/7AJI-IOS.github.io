<!DOCTYPE html>
<html lang="ckb" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>7AJI-IOS | کۆگا</title>
    <style>
        body {
            background-color: #0b0f19;
            color: #f8fafc;
            font-family: -apple-system, BlinkMacSystemFont, sans-serif;
            padding: 20px;
            text-align: center;
        }
        header h1 {
            color: #00d2ff;
            font-size: 35px;
            margin-bottom: 5px;
        }
        header p {
            color: #94a3b8;
            font-size: 14px;
            margin-bottom: 30px;
        }
        .container {
            max-width: 450px;
            margin: 0 auto;
        }
        /* پنێڵی ئەدمین */
        #admin-panel {
            display: none;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid #00d2ff;
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 25px;
        }
        .input-group input {
            width: 100%;
            padding: 12px;
            margin-bottom: 10px;
            background: #111827;
            border: 1px solid #374151;
            color: white;
            border-radius: 10px;
            outline: none;
        }
        .btn {
            background: linear-gradient(135deg, #00d2ff, #0066ff);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 10px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
        }
        /* لیستی کارتەکان */
        .app-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 18px;
            padding: 15px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .app-details {
            text-align: right;
        }
        .app-details h3 {
            font-size: 16px;
            margin-0: 0;
        }
        .app-details p {
            font-size: 12px;
            color: #94a3b8;
            margin-top: 4px;
        }
        .download-btn {
            background: linear-gradient(135deg, #00d2ff, #0066ff);
            color: white;
            text-decoration: none;
            padding: 8px 18px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: bold;
        }
        .delete-btn {
            background: #ff4757;
            color: white;
            border: none;
            padding: 4px 8px;
            border-radius: 5px;
            font-size: 11px;
            margin-top: 5px;
            display: none;
        }
        .login-link {
            color: #94a3b8;
            font-size: 12px;
            margin-top: 30px;
            display: block;
            cursor: pointer;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <header>
        <h1>7AJI-IOS</h1>
        <p>کۆگای فەرمی ئایفۆن 🛡️</p>
    </header>

    <div class="container">
        <div id="admin-panel">
            <h3 style="margin-bottom:10px; color:#00d2ff;">پنێڵی ئەدمین</h3>
            <div class="input-group">
                <input type="text" id="appName" placeholder="ناوی ئەپ">
                <input type="text" id="appSize" placeholder="قەبارە">
                <input type="text" id="appLink" placeholder="لینکی plist">
            </div>
            <button class="btn" onclick="addNewApp()">بڵاوکردنەوە</button>
        </div>

        <h3 style="text-align: right; margin-bottom: 15px; color: #00d2ff;">ئەپەکان:</h3>
        <div id="appsContainer"></div>

        <span class="login-link" onclick="loginAdmin()">🔐 چوونەژوورەوەی ئەدمین</span>
    </div>

    <script>
        // پاسوۆردەکە وەک خۆت ویستت: Haji77
        let isAdmin = false;

        let defaultApps = [
            { name: "Unc0ver Jailbreak", size: "42 MB", link: "itms-services://?action=download-manifest&url=https://example.com/unc0ver.plist" }
        ];

        function loadApps() {
            let apps = localStorage.getItem('7aji_apps');
            if (!apps) {
                localStorage.setItem('7aji_apps', JSON.stringify(defaultApps));
                apps = JSON.stringify(defaultApps);
            }
            
            const appsArray = JSON.parse(apps);
            const container = document.getElementById('appsContainer');
            container.innerHTML = '';

            appsArray.forEach((app, index) => {
                container.innerHTML += `
                    <div class="app-card">
                        <div class="app-details">
                            <h3>${app.name}</h3>
                            <p>قەبارە: ${app.size}</p>
                            <button class="delete-btn" id="del-${index}" onclick="deleteApp(${index})">سڕینەوە</button>
                        </div>
                        <a href="${app.link}" class="download-btn">جێگیرکردن</a>
                    </div>
                `;
            });
            checkAdminView();
        }

        function loginAdmin() {
            const pass = prompt("وشەی نهێنی بنووسە:");
            if (pass === "Haji77") { 
                isAdmin = true;
                document.getElementById('admin-panel').style.display = 'block';
                checkAdminView();
                alert("بەخێرهاتی ئەدمین!");
            } else {
                alert("پاسوۆرد هەڵەیە!");
            }
        }

        function checkAdminView() {
            const deleteButtons = document.querySelectorAll('.delete-btn');
            deleteButtons.forEach(btn => {
                btn.style.display = isAdmin ? 'block' : 'none';
            });
        }

        function addNewApp() {
            const name = document.getElementById('appName').value;
            const size = document.getElementById('appSize').value;
            let link = document.getElementById('appLink').value;

            if (!name || !size || !link) {
                alert("خانەکان پڕبکەرەوە!");
                return;
            }

            if (!link.startsWith("itms-services://")) {
                link = "itms-services://?action=download-manifest&url=" + link;
            }

            let apps = JSON.parse(localStorage.getItem('7aji_apps'));
            apps.push({ name, size, link });
            localStorage.setItem('7aji_apps', JSON.stringify(apps));

            document.getElementById('appName').value = '';
            document.getElementById('appSize').value = '';
            document.getElementById('appLink').value = '';

            loadApps();
        }

        function deleteApp(index) {
            if (confirm("دڵنیای لە سڕینەوە؟")) {
                let apps = JSON.parse(localStorage.getItem('7aji_apps'));
                apps.splice(index, 1);
                localStorage.setItem('7aji_apps', JSON.stringify(apps));
                loadApps();
            }
        }

        window.onload = loadApps;
    </script>
</body>
</html>
