<!DOCTYPE html>
<html lang="ckb" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>7AJI-IOS</title>
    <style>
        body {
            background-color: #0b0f19;
            color: #f8fafc;
            font-family: -apple-system, BlinkMacSystemFont, sans-serif;
            padding: 20px;
            text-align: center;
        }
        header h1 {
            color: #00d2ff;
            font-size: 38px;
            margin-top: 40px;
            font-weight: 900;
        }
        header p {
            color: #94a3b8;
            font-size: 14px;
            margin-bottom: 40px;
        }
        .container {
            max-width: 400px;
            margin: 0 auto;
        }
        .app-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .app-info {
            text-align: right;
        }
        .app-info h3 {
            font-size: 18px;
            margin: 0;
        }
        .app-info p {
            font-size: 13px;
            color: #94a3b8;
            margin: 5px 0 0 0;
        }
        .download-btn {
            background: linear-gradient(135deg, #00d2ff, #0066ff);
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: bold;
        }
        #admin-panel {
            display: none;
            background: rgba(0, 210, 255, 0.05);
            border: 1px solid #00d2ff;
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 30px;
        }
        .input-group input {
            width: 100%;
            padding: 12px;
            margin-bottom: 10px;
            background: #111827;
            border: 1px solid #374151;
            color: white;
            border-radius: 12px;
            outline: none;
        }
        .admin-btn {
            background: #00d2ff;
            color: #0b0f19;
            border: none;
            padding: 12px;
            border-radius: 12px;
            font-weight: bold;
            width: 100%;
            cursor: pointer;
        }
        .delete-btn {
            background: #ff4757;
            color: white;
            border: none;
            padding: 4px 10px;
            border-radius: 6px;
            margin-top: 8px;
            display: none;
            cursor: pointer;
        }
        .footer-btn {
            margin-top: 50px;
            color: #94a3b8;
            font-size: 13px;
            cursor: pointer;
            text-decoration: underline;
            display: block;
        }
    </style>
</head>
<body>

    <header>
        <h1>7AJI-IOS</h1>
        <p>کۆگای فەرمی ئایفۆن 🛡️</p>
    </header>

    <div class="container">
        <div id="admin-panel">
            <h3 style="margin-bottom:15px; color:#00d2ff;">پنێڵی کۆنترۆڵ</h3>
            <div class="input-group">
                <input type="text" id="appName" placeholder="ناوی ئەپ یان یاری">
                <input type="text" id="appSize" placeholder="قەبارە (نموونە: 50 MB)">
                <input type="text" id="appLink" placeholder="لینکی plist">
            </div>
            <button class="admin-btn" onclick="addNewApp()">بڵاوکردنەوە</button>
        </div>

        <div id="appsContainer"></div>

        <span class="footer-btn" onclick="loginAdmin()">🔐 چوونەژوورەوەی ئەدمین</span>
    </div>

    <script>
        let isAdmin = false;
        let defaultApps = [
            { name: "Unc0ver Jailbreak", size: "42 MB", link: "itms-services://?action=download-manifest&url=https://example.com/unc0ver.plist" }
        ];

        function loadApps() {
            let apps = localStorage.getItem('7aji_apps');
            if (!apps) {
                localStorage.setItem('7aji_apps', JSON.stringify(defaultApps));
                apps = JSON.stringify(defaultApps);
            }
            
            const appsArray = JSON.parse(apps);
            const container = document.getElementById('appsContainer');
            container.innerHTML = '';

            appsArray.forEach((app, index) => {
                container.innerHTML += `
                    <div class="app-card">
                        <div class="app-info">
                            <h3>${app.name}</h3>
                            <p>قەبارە: ${app.size}</p>
                            <button class="delete-btn" id="del-${index}" onclick="deleteApp(${index})">سڕینەوە</button>
                        </div>
                        <a href="${app.link}" class="download-btn">جێگیرکردن</a>
                    </div>
                `;
            });
            checkAdminView();
        }

        function loginAdmin() {
            const pass = prompt("وشەی نهێنی ئەدمین بنووسە:");
            if (pass === "Haji77") { 
                isAdmin = true;
                document.getElementById('admin-panel').style.display = 'block';
                checkAdminView();
                alert("خۆشحاڵین بە گەڕانەوەت 7AJI!");
            } else {
                alert("وشەی نهێنی هەڵەیە!");
            }
        }

        function checkAdminView() {
            const deleteButtons = document.querySelectorAll('.delete-btn');
            deleteButtons.forEach(btn => {
                btn.style.display = isAdmin ? 'block' : 'none';
            });
        }

        function addNewApp() {
            const name = document.getElementById('appName').value;
            const size = document.getElementById('appSize').value;
            let link = document.getElementById('appLink').value;

            if (!name || !size || !link) {
                alert("تکایە هەموو خانەکان پڕبکەرەوە!");
                return;
            }

            if (!link.startsWith("itms-services://")) {
                link = "itms-services://?action=download-manifest&url=" + link;
            }

            let apps = JSON.parse(localStorage.getItem('7aji_apps'));
            apps.push({ name, size, link });
            localStorage.setItem('7aji_apps', JSON.stringify(apps));

            document.getElementById('appName').value = '';
            document.getElementById('appSize').value = '';
            document.getElementById('appLink').value = '';

            loadApps();
        }

        function deleteApp(index) {
            if (confirm("دڵنیای لە سڕینەوەی ئەم ئەپە؟")) {
                let apps = JSON.parse(localStorage.getItem('7aji_apps'));
                apps.splice(index, 1);
                localStorage.setItem('7aji_apps', JSON.stringify(apps));
                loadApps();
            }
        }

        window.onload = loadApps;
    </script>
</body>
</html>
