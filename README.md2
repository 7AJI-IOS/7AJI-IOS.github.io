<!DOCTYPE html>
<html lang="ckb" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>7AJI-IOS | جێگیرکردنی ڕاستەوخۆ</title>
    <style>
        :root {
            --primary: #00d2ff;
            --secondary: #0066ff;
            --bg-gradient: linear-gradient(135deg, #0b0f19, #111827);
            --glass-bg: rgba(255, 255, 255, 0.05);
            --glass-border: rgba(255, 255, 255, 0.08);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        body {
            background: var(--bg-gradient);
            color: var(--text-main);
            min-height: 100vh;
            padding-bottom: 60px;
            overflow-x: hidden;
        }

        .welcome-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(11, 15, 25, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            z-index: 1000;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            transition: opacity 0.5s ease;
        }

        .welcome-box {
            text-align: center;
            padding: 30px;
            border-radius: 24px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--glass-border);
            max-width: 85%;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        }

        .welcome-box h2 {
            font-size: 24px;
            margin-bottom: 10px;
            color: var(--primary);
            text-shadow: 0 0 15px rgba(0, 210, 255, 0.4);
        }

        .welcome-box p {
            color: var(--text-muted);
            font-size: 14px;
            margin-bottom: 20px;
        }

        .enter-btn {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border: none;
            padding: 12px 35px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 16px;
            cursor: pointer;
        }

        header {
            background: rgba(11, 15, 25, 0.7);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            position: sticky;
            top: 0;
            z-index: 100;
            padding: 25px;
            text-align: center;
            border-bottom: 1px solid var(--glass-border);
        }

        .logo-container {
            display: inline-block;
            position: relative;
        }

        header h1 {
            font-size: 32px;
            font-weight: 900;
            background: linear-gradient(to right, #00d2ff, #0066ff, #00d2ff);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shine 3s linear infinite;
            letter-spacing: 2px;
        }

        @keyframes shine {
            to { background-position: 200% center; }
        }

        header p {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 6px;
        }

        .container {
            padding: 20px;
            max-width: 480px;
            margin: 0 auto;
        }

        #admin-panel {
            display: none;
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(0, 210, 255, 0.2);
            border-radius: 24px;
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        #admin-panel h2 {
            font-size: 18px;
            margin-bottom: 15px;
            color: var(--primary);
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 15px;
        }

        input {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--glass-border);
            padding: 14px;
            border-radius: 14px;
            color: white;
            font-size: 15px;
            outline: none;
        }

        input:focus {
            border-color: var(--primary);
            background: rgba(255, 255, 255, 0.08);
        }

        button {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border: none;
            padding: 14px;
            border-radius: 14px;
            font-weight: bold;
            font-size: 16px;
        }

        .section-title {
            font-size: 18px;
            margin: 20px 0 15px 0;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(to left, rgba(0, 210, 255, 0.3), transparent);
        }

        .apps-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .app-card {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 22px;
            padding: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .app-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .app-icon {
            width: 58px;
            height: 58px;
            border-radius: 16px;
            background: linear-gradient(45deg, #1e293b, #0f172a);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 18px;
            color: var(--primary);
            border: 1px solid var(--glass-border);
        }

        .app-details h3 {
            font-size: 16px;
            color: var(--text-main);
            font-weight: 600;
        }

        .app-details p {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .download-btn {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            padding: 10px 22px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: bold;
            text-decoration: none;
            box-shadow: 0 4px 15px rgba(0, 210, 255, 0.2);
        }

        .delete-btn {
            background: #ff4757;
            color: white;
            padding: 6px 12px;
            border-radius: 10px;
            font-size: 11px;
            margin-top: 6px;
            border: none;
            display: none;
        }

        .footer-admin-btn {
            text-align: center;
            margin-top: 40px;
        }

        .footer-admin-btn span {
            font-size: 13px;
            color: var(--text-muted);
            opacity: 0.6;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="welcome-overlay" id="welcomeOverlay">
        <div class="welcome-box">
            <h2>سڵاو، بەخێربێیت! 👋</h2>
            <p>بەخێربێیت بۆ وێبسایتی فەرمی 7AJI-IOS بۆ جێگیرکردنی ڕاستەوخۆی ئەپەکان.</p>
            <button class="enter-btn" onclick="closeWelcome()">چوونە ناو وێبسایت</button>
        </div>
    </div>

    <header>
        <div class="logo-container">
            <h1>7AJI-IOS</h1>
        </div>
        <p>کۆگای فەرمی بۆ جێگیرکردنی ڕاستەوخۆی ئەپەکان لەسەر ئایفۆن</p>
    </header>

    <div class="container">

        <div id="admin-panel">
            <h2>پنێڵی بەڕێوبەر (7AJI)</h2>
            <div class="input-group">
                <input type="text" id="appName" placeholder="ناوی بەرنامە یان یاری">
                <input type="text" id="appSize" placeholder="قەبارە (بۆ نموونە: 65 MB)">
                <input type="text" id="appLink" placeholder="لینکی plist یان لینکی ڕاستەوخۆ">
            </div>
            <button onclick="addNewApp()">بڵاوکردنەوەی ئەپ</button>
        </div>

        <h2 class="section-title">ئەپە بەردەستەکان</h2>
        
        <div class="apps-list" id="appsContainer"></div>

        <div class="footer-admin-btn">
            <span onclick="loginAdmin()">🔐 چوونەژوورەوەی ئەدمین</span>
        </div>
    </div>

    <script>
        const ADMIN_PASSWORD = "1234"; 
        let isAdmin = false;

        function closeWelcome() {
            document.getElementById('welcomeOverlay').style.opacity = '0';
            setTimeout(() => {
                document.getElementById('welcomeOverlay').style.display = 'none';
            }, 500);
        }

        // نموونەی چۆنیەتی کارکردنی لینکی ڕاستەوخۆ بۆ ئایفۆن
        let defaultApps = [
            { name: "Unc0ver Jailbreak", size: "42 MB", link: "itms-services://?action=download-manifest&url=https://example.com/unc0ver.plist" },
            { name: "TikTok Plus", size: "88 MB", link: "itms-services://?action=download-manifest&url=https://example.com/tiktok.plist" }
        ];

        function loadApps() {
            let apps = localStorage.getItem('7aji_apps');
            if (!apps) {
                localStorage.setItem('7aji_apps', JSON.stringify(defaultApps));
                apps = JSON.stringify(defaultApps);
            }
            
            const appsArray = JSON.parse(apps);
            const container = document.getElementById('appsContainer');
            container.innerHTML = '';

            appsArray.forEach((app, index) => {
                const shortName = app.name.substring(0, 2).toUpperCase();
                
                container.innerHTML += `
                    <div class="app-card">
                        <div class="app-info">
                            <div class="app-icon">${shortName}</div>
                            <div class="app-details">
                                <h3>${app.name}</h3>
                                <p>قەبارە: ${app.size}</p>
                                <button class="delete-btn" id="del-${index}" onclick="deleteApp(${index})">سڕینەوە</button>
                            </div>
                        </div>
                        <a href="${app.link}" class="download-btn">جێگیرکردن</a>
                    </div>
                `;
            });
            checkAdminView();
        }

        function loginAdmin() {
            const pass = prompt("تکایە وشەی نهێنی ئەدمین بنووسە:");
            if (pass === ADMIN_PASSWORD) {
                isAdmin = true;
                document.getElementById('admin-panel').style.display = 'block';
                checkAdminView();
                alert("بەخێرهاتی 7AJI.");
            } else {
                alert("وشەی نهێنی هەڵەیە!");
            }
        }

        function checkAdminView() {
            const deleteButtons = document.querySelectorAll('.delete-btn');
            deleteButtons.forEach(btn => {
                btn.style.display = isAdmin ? 'block' : 'none';
            });
        }

        function addNewApp() {
            const name = document.getElementById('appName').value;
            const size = document.getElementById('appSize').value;
            let link = document.getElementById('appLink').value;

            if (!name || !size || !link) {
                alert("تکایە هەموو زانیارییەکان پڕبکەرەوە!");
                return;
            }

            // ئەگەر خۆت پێشگرەکەت نەنووسیبێت، کۆدەکە خۆکارانە بۆت دەکاتە سیستەمی ئایفۆن
            if (!link.startsWith("itms-services://")) {
                link = "itms-services://?action=download-manifest&url=" + link;
            }

            let apps = JSON.parse(localStorage.getItem('7aji_apps'));
            apps.push({ name, size, link });
            localStorage.setItem('7aji_apps', JSON.stringify(apps));

            document.getElementById('appName').value = '';
            document.getElementById('appSize').value = '';
            document.getElementById('appLink').value = '';

            loadApps();
        }

        function deleteApp(index) {
            if (confirm("دڵنیای لە سڕینەوە؟")) {
                let apps = JSON.parse(localStorage.getItem('7aji_apps'));
                apps.splice(index, 1);
                localStorage.setItem('7aji_apps', JSON.stringify(apps));
                loadApps();
            }
        }

        window.onload = loadApps;
    </script>
</body>
</html>
